POSTGRES_DB=probeacon
POSTGRES_USER=probeacon
POSTGRES_PASSWORD=probeacon_dev

CLICKHOUSE_DB=probeacon
CLICKHOUSE_USER=probeacon
CLICKHOUSE_PASSWORD=probeacon_dev

RABBITMQ_DEFAULT_USER=probeacon
RABBITMQ_DEFAULT_PASS=probeacon_dev
RABBITMQ_DEFAULT_VHOST=probeacon
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_EMAIL_QUEUE=probeacon.email

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8080
APP_FRONTEND_URL=http://localhost:5173

API_DEFAULT_CONNECTION=Host=postgres;Port=5432;Database=probeacon;Username=probeacon;Password=probeacon_dev

JWT_SECRET=change-this-to-a-long-random-secret-in-production-min-32-chars
JWT_EXPIRY_MINUTES=15
JWT_ISSUER=probeacon
JWT_AUDIENCE=probeacon

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=ProBeacon
EMAIL_ENABLE_SSL=true
