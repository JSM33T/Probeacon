# Copy this file to .env for local Docker usage.
# Replace all change-me values before deploying or exposing services.

POSTGRES_DB=probeacon
POSTGRES_USER=probeacon
POSTGRES_PASSWORD=change-me-postgres-password

CLICKHOUSE_DB=probeacon
CLICKHOUSE_USER=probeacon
CLICKHOUSE_PASSWORD=change-me-clickhouse-password

RABBITMQ_DEFAULT_USER=probeacon
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_DEFAULT_VHOST=probeacon
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_EMAIL_QUEUE=probeacon.email

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_HTTP_PORTS=8081
APP_FRONTEND_URL=http://localhost:5173
APP_DEPLOYMENT_MODE=SelfHosted

DEMO_WORKSPACE_LIFETIME_HOURS=48
DEMO_CLEANUP_INTERVAL_MINUTES=60

API_DEFAULT_CONNECTION=Host=postgres;Port=5432;Database=probeacon;Username=probeacon;Password=change-me-postgres-password

JWT_SECRET=change-me-random-jwt-secret-at-least-32-chars
JWT_EXPIRY_MINUTES=15
JWT_ISSUER=probeacon
JWT_AUDIENCE=probeacon

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=ProBeacon
EMAIL_ENABLE_SSL=true
